# NoteMeet Environment Configuration

# Gmail credentials for sending waitlist notifications
# Use a Gmail App Password (not your regular password)
# Get one at: https://myaccount.google.com/apppasswords
EMAIL_FROM=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password-here

# Cloudflare Turnstile — bot protection
# Get your free keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Site key goes in index.html, secret key goes here
TURNSTILE_SECRET=your-turnstile-secret-key-here
